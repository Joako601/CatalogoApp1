<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>CatalogoApp - Database</title>
    <link rel="stylesheet" href="~/css/site.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Segoe+UI:wght@400;600;700&display=swap" rel="stylesheet">
</head>
<body>

    <header class="moby-header">
        <div class="moby-nav-container">
            <div class="moby-brand">
                <a class="moby-logo" href="/">📊 <span class="logo-text">Catalogo</span><span class="logo-sub">App</span></a>
            </div>
            <nav class="moby-nav">
                <a href="/">Browse</a>
                <a href="/Catalogo">Contribute</a>
                <a href="/Catalogo/Agregar" class="moby-btn-nav">Add Item</a>
            </nav>
        </div>
        <div class="moby-accent-bar"></div>
    </header>

    <main class="moby-main">
        @RenderBody()
    </main>

    <footer class="moby-footer">
        <p>&copy; 2026 CatalogoApp Database. All statistics and data are for educational purposes.</p>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>