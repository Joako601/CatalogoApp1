@{
    ViewData["Title"] = "Registro";
}

<div class="auth-wrapper">
    <div class="auth-card">
        <h1>🎮 Crear cuenta</h1>

        @if (ViewBag.Error != null)
        {
            <div class="alert alert-danger">@ViewBag.Error</div>
        }

        <form asp-action="Registro" method="post">
            <div class="form-group">
                <label>Nombre de usuario</label>
                <input type="text" name="nombreUsuario" class="form-control" placeholder="Elige un nombre único" required autofocus />
            </div>

            <div class="form-group">
                <label>Email</label>
                <input type="email" name="email" class="form-control" placeholder="tu@email.com" required />
            </div>

            <div class="form-group">
                <label>Contraseña</label>
                <input type="password" name="password" class="form-control" placeholder="Mínimo 4 caracteres" required />
            </div>

            <div class="form-group">
                <label>Confirmar contraseña</label>
                <input type="password" name="confirmar" class="form-control" placeholder="Repite tu contraseña" required />
            </div>

            <button type="submit" class="btn btn-primary" style="width:100%;margin-top:0.5rem;">Crear cuenta</button>
        </form>

        <div class="auth-link">
            ¿Ya tienes cuenta? <a asp-action="Login">Inicia sesión</a>
        </div>
    </div>
</div>