@model dynamic

@{
    ViewData["Title"] = "Registrarse";
}

<div style="max-width: 440px; margin: 4rem auto; padding: 0 1rem;">

    <div class="moby-block">
        <div class="moby-block-title" style="justify-content: center; padding-bottom: 0.8rem;">
            <span style="font-size: 1.15rem; color: #fff; letter-spacing: -0.3px;">📝 SISTEMA DE REGISTRO</span>
        </div>

        <p style="text-align: center; color: var(--moby-text-muted); font-size: 0.85rem; margin-bottom: 1.5rem;">
            Crea una nueva identidad para indexar títulos y redactar reseñas.
        </p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div style="background-color: rgba(255, 77, 77, 0.1); border: 1px solid #ff4d4d; color: #ff4d4d; padding: 0.8rem; margin-bottom: 1.2rem; border-radius: 4px; font-size: 0.85rem;">
                <div asp-validation-summary="All" style="list-style: none; padding-left: 0;"></div>
            </div>
        }

        <form asp-controller="Usuario" asp-action="Registro" method="post">

            <div class="moby-form-group" style="margin-bottom: 1.2rem;">
                <label class="moby-label" for="nombreUsuario">Nuevo Usuario / Identificador</label>
                <input type="text" name="nombreUsuario" id="nombreUsuario" class="moby-input" required autocomplete="off" placeholder="Ej: Joako601" />
                <span style="font-size: 0.75rem; color: var(--moby-text-muted); display:block; margin-top: 0.2rem;">Este nombre se estampará públicamente en tus aportes.</span>
            </div>

            <div class="moby-form-group" style="margin-bottom: 1.2rem;">
                <label class="moby-label" for="email">Correo Electrónico</label>
                <input type="email" name="email" id="email" class="moby-input" required placeholder="tu@correo.com" />
            </div>

            <div class="moby-form-group" style="margin-bottom: 1.2rem;">
                <label class="moby-label" for="password">Contraseña</label>
                <input type="password" name="password" id="password" class="moby-input" required placeholder="••••••••" />
            </div>

            <div class="moby-form-group" style="margin-bottom: 1.5rem;">
                <label class="moby-label" for="confirmar">Confirmar Contraseña</label>
                <input type="password" name="confirmar" id="confirmar" class="moby-input" required placeholder="••••••••" />
            </div>

            <button type="submit" class="moby-btn" style="width: 100%; padding: 0.65rem; font-size: 0.9rem; text-transform: uppercase; letter-spacing: 0.5px;">
                Crear Nueva Cuenta
            </button>
        </form>

        <div style="border-top: 1px solid var(--moby-border); margin-top: 1.5rem; padding-top: 1rem; text-align: center; font-size: 0.85rem;">
            <span style="color: var(--moby-text-muted);">¿Ya eres miembro verificado?</span>
            <a asp-controller="Usuario" asp-action="Login" style="color: var(--moby-blue); text-decoration: none; font-weight: 600; margin-left: 0.3rem;">Inicia Sesión aquí</a>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}