@model List<CatalogoApp.Domain.Models.Item>

@{
    ViewData["Title"] = "Catálogo";
}

<div class="moby-grid">

    <div class="moby-block">
        <div class="moby-block-title">
            <span>▼ @(ViewBag.GeneroActual ?? "All Video Games")</span>
            <span style="color: var(--moby-text-muted); font-weight: normal; font-size: 0.85rem;">
                @Model.Count titles found
            </span>
        </div>

        @if (Model.Count == 0)
        {
            <div style="text-align: center; padding: 3rem 1rem; color: var(--moby-text-muted);">
                <div style="font-size: 2rem; margin-bottom: 0.5rem;">🎮</div>
                <p>No games registered in this section yet.</p>
            </div>
        }
        else
        {
            <ul class="moby-list">
                @{
                    int index = 1;
                }
                @foreach (var item in Model)
                {
                    <li class="moby-list-item">
                        <span class="moby-rank">#@index</span>

                        <div style="display: flex; flex-direction: column; gap: 2px;">
                            <a asp-controller="Catalogo" asp-action="Detalle" asp-route-id="@item.Id" class="moby-item-name">
                                @item.Titulo
                            </a>
                            <div style="font-size: 0.78rem; color: var(--moby-text-muted);">
                                <span>@item.Consola</span> • <span>@item.Genero</span>
                            </div>
                        </div>

                        <span class="moby-stat-value" style="font-weight: 600;">
                            @item.Ano
                        </span>
                    </li>
                    index++;
                }
            </ul>
        }
    </div>

    <div class="moby-side-columns">

        <div class="moby-block">
            <div class="moby-block-title">
                <span>Contribute</span>
            </div>
            @if (ViewBag.UsuarioLogueado != null)
            {
                <div style="padding: 0.2rem 0;">
                    <p style="color: var(--moby-text-muted); margin-bottom: 0.8rem; font-size: 0.85rem;">
                        You are authorized to add content.
                    </p>
                    <a asp-controller="Catalogo" asp-action="Agregar" class="moby-btn" style="display: block; text-align: center; text-decoration: none;">
                        + Add Video Game
                    </a>
                </div>
            }
            else
            {
                <p style="font-size: 0.85rem; color: var(--moby-text-muted); line-height: 1.4;">
                    <a asp-controller="Usuario" asp-action="Login" style="color: var(--moby-blue); text-decoration: none; font-weight: 600;">Log In</a> to submit new games to the database.
                </p>
            }
        </div>

        <div class="moby-block">
            <div class="moby-block-title">
                <span>Browse by Genre</span>
            </div>
            <ul class="moby-list">
                <li class="moby-list-item" style="padding: 0.3rem 0;">
                    <a asp-controller="Catalogo" asp-action="Index"
                       style="text-decoration: none; font-weight: @(ViewBag.GeneroActual == null ? "700" : "400"); color: @(ViewBag.GeneroActual == null ? "var(--moby-blue)" : "var(--moby-text-muted)");">
                        [ All Genres ]
                    </a>
                </li>
                @foreach (var gen in ViewBag.Generos as List<string>)
                {
                    <li class="moby-list-item" style="padding: 0.3rem 0;">
                        <a asp-controller="Catalogo" asp-action="Index" asp-route-genero="@gen"
                           style="text-decoration: none; font-weight: @(ViewBag.GeneroActual == gen ? "700" : "400"); color: @(ViewBag.GeneroActual == gen ? "var(--moby-blue)" : "var(--moby-text)");">
                            @gen
                        </a>
                    </li>
                }
            </ul>
        </div>

    </div>
</div>