@model CatalogoApp.Domain.Models.Item
@{
    ViewData["Title"] = "Agregar videojuego";
}

<h1>Agregar videojuego</h1>

<p style="color:var(--color-texto-muted);">Completa los datos del nuevo juego</p>

<div class="form-card" style="margin-top:1.5rem;">
    <form asp-action="Agregar" method="post">
        <div class="form-group">
            <label>Título</label>
            <input asp-for="Titulo" class="form-control" placeholder="Ej: The Legend of Zelda" />
        </div>

        <div class="form-group">
            <label>Género</label>
            <input asp-for="Genero" class="form-control" placeholder="Ej: RPG, Acción, Metroidvania..." />
        </div>

        <div class="form-group">
            <label>Consola</label>
            <input asp-for="Consola" class="form-control" placeholder="Ej: Nintendo Switch, PS5..." />
        </div>

        <div class="form-group">
            <label>Año</label>
            <input asp-for="Ano" type="number" class="form-control" placeholder="Ej: 2023" min="1970" max="2030" />
        </div>

        <div class="form-group">
            <label>Descripción</label>
            <textarea asp-for="Descripcion" class="form-control" rows="4" placeholder="Breve descripción del juego..."></textarea>
        </div>

        <div style="display:flex;gap:0.8rem;margin-top:1.5rem;">
            <button type="submit" class="btn btn-primary">💾 Guardar juego</button>
            <a asp-action="Index" class="btn btn-outline">Cancelar</a>
        </div>
    </form>
</div>